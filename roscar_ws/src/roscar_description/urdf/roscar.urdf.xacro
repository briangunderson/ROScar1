<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="roscar">

  <!-- Include D435i macro from realsense2_description -->
  <xacro:include filename="$(find realsense2_description)/urdf/_d435i.urdf.xacro"/>

  <!-- ==================== Robot Dimensions ==================== -->
  <!-- MEASURED 2026-03-16 with calipers and tape measure            -->
  <xacro:property name="chassis_length" value="0.200"/>   <!-- m, front-to-back (body, not incl wheel protrusion) -->
  <xacro:property name="chassis_width" value="0.170"/>    <!-- m, left-to-right (body between wheels) -->
  <xacro:property name="chassis_height" value="0.060"/>   <!-- m, plate/board stack thickness -->
  <xacro:property name="chassis_z_offset" value="0.0205"/> <!-- m, ground to bottom of chassis (measured) -->

  <xacro:property name="wheel_radius" value="0.0397"/>    <!-- m, 79.3mm dia across mecanum rollers -->
  <xacro:property name="wheel_width" value="0.0373"/>     <!-- m, hub face to face incl rollers -->

  <!-- Half-distances from center to wheel axes -->
  <xacro:property name="wheel_x_offset" value="0.0483"/>  <!-- m, half of 96.55mm wheelbase -->
  <xacro:property name="wheel_y_offset" value="0.1025"/>  <!-- m, half of 205mm track width -->

  <!-- Camera position (relative to base_link) — TODO: measure precisely -->
  <xacro:property name="camera_x" value="0.12"/>
  <xacro:property name="camera_z" value="0.10"/>

  <!-- Lidar position (relative to base_link) — TODO: measure precisely -->
  <xacro:property name="lidar_x" value="0.0"/>
  <xacro:property name="lidar_z" value="0.09"/>  <!-- scan plane ~18cm from floor -->

  <!-- D435i depth camera position (relative to base_link) — front-facing, tilted slightly down -->
  <!-- TODO: measure after physical mount — placeholder values below -->
  <xacro:property name="d435i_x" value="0.09"/>    <!-- m, forward of center -->
  <xacro:property name="d435i_y" value="0.0"/>     <!-- m, centered -->
  <xacro:property name="d435i_z" value="0.07"/>    <!-- m, above base_link -->
  <xacro:property name="d435i_pitch" value="0.175"/>  <!-- rad, ~10deg down tilt -->

  <!-- ==================== Materials ==================== -->
  <material name="dark_grey">
    <color rgba="0.3 0.3 0.3 1.0"/>
  </material>
  <material name="black">
    <color rgba="0.1 0.1 0.1 1.0"/>
  </material>
  <material name="blue">
    <color rgba="0.2 0.2 0.8 1.0"/>
  </material>

  <!-- ==================== Base Footprint ==================== -->
  <!-- Virtual frame on the ground plane, directly below base_link -->
  <link name="base_footprint"/>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 ${chassis_z_offset + chassis_height/2}" rpy="0 0 0"/>
  </joint>

  <!-- ==================== Base Link (Chassis) ==================== -->
  <link name="base_link">
    <visual>
      <geometry>
        <box size="${chassis_length} ${chassis_width} ${chassis_height}"/>
      </geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <geometry>
        <box size="${chassis_length} ${chassis_width} ${chassis_height}"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="2.2"/>  <!-- measured total 2200g, minus ~400g for 4 wheels -->
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
  </link>

  <!-- ==================== Wheel Macro ==================== -->
  <xacro:macro name="mecanum_wheel" params="name x_pos y_pos">
    <link name="${name}_wheel_link">
      <visual>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
        <material name="black"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="0.2"/>
        <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
      </inertial>
    </link>

    <joint name="${name}_wheel_joint" type="continuous">
      <parent link="base_link"/>
      <child link="${name}_wheel_link"/>
      <origin xyz="${x_pos} ${y_pos} ${-(chassis_z_offset + chassis_height/2 - wheel_radius)}"
              rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
    </joint>
  </xacro:macro>

  <!-- ==================== Four Wheels ==================== -->
  <xacro:mecanum_wheel name="front_left"  x_pos="${wheel_x_offset}"  y_pos="${wheel_y_offset}"/>
  <xacro:mecanum_wheel name="front_right" x_pos="${wheel_x_offset}"  y_pos="${-wheel_y_offset}"/>
  <xacro:mecanum_wheel name="rear_left"   x_pos="${-wheel_x_offset}" y_pos="${wheel_y_offset}"/>
  <xacro:mecanum_wheel name="rear_right"  x_pos="${-wheel_x_offset}" y_pos="${-wheel_y_offset}"/>

  <!-- ==================== IMU Link ==================== -->
  <link name="imu_link"/>

  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- ==================== Logitech Webcam Link ==================== -->
  <!-- NOTE: renamed from camera_link to webcam_link to free the "camera_link"
       name for realsense2_description's D435i macro (below). Any consumer that
       used camera_optical_frame should use webcam_optical_frame now. -->
  <link name="webcam_link">
    <visual>
      <geometry>
        <box size="0.03 0.08 0.03"/>
      </geometry>
      <material name="blue"/>
    </visual>
  </link>

  <joint name="webcam_joint" type="fixed">
    <parent link="base_link"/>
    <child link="webcam_link"/>
    <origin xyz="${camera_x} 0 ${camera_z}" rpy="0 0 0"/>
  </joint>

  <!-- Optical frame: z forward, x right, y down (REP 103) -->
  <link name="webcam_optical_frame"/>

  <joint name="webcam_optical_joint" type="fixed">
    <parent link="webcam_link"/>
    <child link="webcam_optical_frame"/>
    <origin xyz="0 0 0" rpy="${-pi/2} 0 ${-pi/2}"/>
  </joint>

  <!-- ==================== D435i Depth Camera ==================== -->
  <!-- realsense2_description's sensor_d435i macro creates:
         camera_link (body), camera_depth_frame, camera_color_frame,
         camera_accel_frame, camera_gyro_frame, and their _optical variants.
       Parented to base_link at the mount pose defined above. -->
  <xacro:sensor_d435i parent="base_link" name="camera" use_nominal_extrinsics="true">
    <origin xyz="${d435i_x} ${d435i_y} ${d435i_z}" rpy="0 ${d435i_pitch} 0"/>
  </xacro:sensor_d435i>

  <!-- ==================== Lidar Link (RPLIDAR C1) ==================== -->
  <link name="laser">
    <visual>
      <geometry>
        <cylinder radius="0.035" length="0.025"/>
      </geometry>
      <material name="blue"/>
    </visual>
  </link>

  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="laser"/>
    <origin xyz="${lidar_x} 0 ${lidar_z}" rpy="0 0 ${pi}"/>
  </joint>

</robot>
