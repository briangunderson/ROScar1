<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="roscar">

  <!-- ==================== Robot Dimensions ==================== -->
  <!-- PLACEHOLDER VALUES: Measure your robot and update these!   -->
  <xacro:property name="chassis_length" value="0.25"/>   <!-- m, front-to-back -->
  <xacro:property name="chassis_width" value="0.20"/>    <!-- m, left-to-right -->
  <xacro:property name="chassis_height" value="0.08"/>   <!-- m, plate thickness -->
  <xacro:property name="chassis_z_offset" value="0.05"/> <!-- m, ground to bottom of chassis -->

  <xacro:property name="wheel_radius" value="0.033"/>    <!-- m -->
  <xacro:property name="wheel_width" value="0.04"/>      <!-- m -->

  <!-- Half-distances from center to wheel axes -->
  <xacro:property name="wheel_x_offset" value="0.10"/>   <!-- m, half wheelbase (front-rear) -->
  <xacro:property name="wheel_y_offset" value="0.12"/>   <!-- m, half track width (left-right) -->

  <!-- Camera position (relative to base_link) -->
  <xacro:property name="camera_x" value="0.12"/>
  <xacro:property name="camera_z" value="0.10"/>

  <!-- Lidar position (relative to base_link) -->
  <xacro:property name="lidar_x" value="0.0"/>
  <xacro:property name="lidar_z" value="0.12"/>  <!-- top of chassis -->

  <!-- ==================== Materials ==================== -->
  <material name="dark_grey">
    <color rgba="0.3 0.3 0.3 1.0"/>
  </material>
  <material name="black">
    <color rgba="0.1 0.1 0.1 1.0"/>
  </material>
  <material name="blue">
    <color rgba="0.2 0.2 0.8 1.0"/>
  </material>

  <!-- ==================== Base Footprint ==================== -->
  <!-- Virtual frame on the ground plane, directly below base_link -->
  <link name="base_footprint"/>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 ${chassis_z_offset + chassis_height/2}" rpy="0 0 0"/>
  </joint>

  <!-- ==================== Base Link (Chassis) ==================== -->
  <link name="base_link">
    <visual>
      <geometry>
        <box size="${chassis_length} ${chassis_width} ${chassis_height}"/>
      </geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <geometry>
        <box size="${chassis_length} ${chassis_width} ${chassis_height}"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="2.0"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
  </link>

  <!-- ==================== Wheel Macro ==================== -->
  <xacro:macro name="mecanum_wheel" params="name x_pos y_pos">
    <link name="${name}_wheel_link">
      <visual>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
        <material name="black"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="0.2"/>
        <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
      </inertial>
    </link>

    <joint name="${name}_wheel_joint" type="continuous">
      <parent link="base_link"/>
      <child link="${name}_wheel_link"/>
      <origin xyz="${x_pos} ${y_pos} ${-(chassis_z_offset + chassis_height/2 - wheel_radius)}"
              rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
    </joint>
  </xacro:macro>

  <!-- ==================== Four Wheels ==================== -->
  <xacro:mecanum_wheel name="front_left"  x_pos="${wheel_x_offset}"  y_pos="${wheel_y_offset}"/>
  <xacro:mecanum_wheel name="front_right" x_pos="${wheel_x_offset}"  y_pos="${-wheel_y_offset}"/>
  <xacro:mecanum_wheel name="rear_left"   x_pos="${-wheel_x_offset}" y_pos="${wheel_y_offset}"/>
  <xacro:mecanum_wheel name="rear_right"  x_pos="${-wheel_x_offset}" y_pos="${-wheel_y_offset}"/>

  <!-- ==================== IMU Link ==================== -->
  <link name="imu_link"/>

  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- ==================== Camera Link ==================== -->
  <link name="camera_link">
    <visual>
      <geometry>
        <box size="0.03 0.08 0.03"/>
      </geometry>
      <material name="blue"/>
    </visual>
  </link>

  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link"/>
    <origin xyz="${camera_x} 0 ${camera_z}" rpy="0 0 0"/>
  </joint>

  <!-- Optical frame: z forward, x right, y down (REP 103) -->
  <link name="camera_optical_frame"/>

  <joint name="camera_optical_joint" type="fixed">
    <parent link="camera_link"/>
    <child link="camera_optical_frame"/>
    <origin xyz="0 0 0" rpy="${-pi/2} 0 ${-pi/2}"/>
  </joint>

  <!-- ==================== Lidar Link (RPLIDAR C1) ==================== -->
  <link name="laser">
    <visual>
      <geometry>
        <cylinder radius="0.035" length="0.025"/>
      </geometry>
      <material name="blue"/>
    </visual>
  </link>

  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="laser"/>
    <origin xyz="${lidar_x} 0 ${lidar_z}" rpy="0 0 0"/>
  </joint>

</robot>
