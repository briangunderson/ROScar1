<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="roscar">

  <!-- Include D435i macro from realsense2_description -->
  <xacro:include filename="$(find realsense2_description)/urdf/_d435i.urdf.xacro"/>

  <!-- ==================== Coordinate Convention ==================== -->
  <!-- base_link: +X = camera mast direction (operator forward), +Y = left,    -->
  <!-- +Z = up (REP 103). Driver runs no vx/vy negation in this state — motor  -->
  <!-- wiring matches firmware labels and base_link aligns with the firmware   -->
  <!-- chassis frame.                                                          -->

  <!-- ==================== Robot Dimensions (Chassis v2 — extrusion) ============ -->
  <!-- ESTIMATES from photos 2026-04-27. TODO: remeasure with calipers/tape:    -->
  <!--   wheelbase, track, mast_x, mast_height, d435i_z, lidar_z.               -->
  <xacro:property name="chassis_length" value="0.220"/>   <!-- ESTIMATE -->
  <xacro:property name="chassis_width"  value="0.250"/>   <!-- MEASURED 2026-04-28: 250mm extrusion frame width -->
  <xacro:property name="chassis_height" value="0.080"/>   <!-- ESTIMATE: extrusion stack -->
  <xacro:property name="chassis_z_offset" value="0.0205"/> <!-- ground to bottom of frame -->

  <xacro:property name="wheel_radius" value="0.0397"/>    <!-- 79.3mm dia mecanum -->
  <xacro:property name="wheel_width"  value="0.0373"/>

  <!-- Half-distances from chassis center to wheel hubs.                       -->
  <!-- MEASURED 2026-04-28: wheelbase 213mm (76mm rear-of-frame→rear-wheel,    -->
  <!-- 289mm rear-of-frame→front-wheel), track 325mm.                          -->
  <xacro:property name="wheel_x_offset" value="0.1065"/>  <!-- half wheelbase 213mm -->
  <xacro:property name="wheel_y_offset" value="0.1625"/>  <!-- half track 325mm -->

  <!-- Mast (3030 extrusion column at front of chassis, holds lidar + camera) -->
  <xacro:property name="mast_x"        value="0.090"/>    <!-- ESTIMATE: forward of base_link center -->
  <xacro:property name="mast_y"        value="0.015"/>    <!-- MEASURED 2026-04-28: 110mm from left edge of 250mm frame → 15mm left of center -->
  <xacro:property name="mast_height"   value="0.220"/>    <!-- ESTIMATE: column length above chassis top -->
  <xacro:property name="mast_section"  value="0.030"/>    <!-- 30mm extrusion -->

  <!-- D435i camera mounted on the front face of the mast, looking +X.        -->
  <!-- ESTIMATE — please measure ground to camera optical-center height.       -->
  <xacro:property name="d435i_x"     value="${mast_x + mast_section/2}"/>
  <xacro:property name="d435i_y"     value="${mast_y}"/>
  <xacro:property name="d435i_z"     value="0.150"/>      <!-- ESTIMATE: above base_link -->
  <xacro:property name="d435i_pitch" value="0.0"/>        <!-- horizontal -->

  <!-- Lidar sits on top of the mast.                                          -->
  <!-- ESTIMATE — please measure ground to scan-plane height.                  -->
  <xacro:property name="lidar_x" value="${mast_x}"/>
  <xacro:property name="lidar_y" value="${mast_y}"/>
  <xacro:property name="lidar_z" value="${mast_height + 0.015}"/>  <!-- mast top + ~15mm to scan plane -->

  <!-- ==================== Materials ==================== -->
  <material name="dark_grey">
    <color rgba="0.3 0.3 0.3 1.0"/>
  </material>
  <material name="roscar_aluminum">
    <color rgba="0.75 0.75 0.78 1.0"/>
  </material>
  <material name="black">
    <color rgba="0.1 0.1 0.1 1.0"/>
  </material>
  <material name="blue">
    <color rgba="0.2 0.2 0.8 1.0"/>
  </material>

  <!-- ==================== Base Footprint ==================== -->
  <link name="base_footprint"/>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 ${chassis_z_offset + chassis_height/2}" rpy="0 0 0"/>
  </joint>

  <!-- ==================== Base Link (Chassis) ==================== -->
  <link name="base_link">
    <visual>
      <geometry>
        <box size="${chassis_length} ${chassis_width} ${chassis_height}"/>
      </geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <geometry>
        <box size="${chassis_length} ${chassis_width} ${chassis_height}"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="3.5"/>  <!-- ESTIMATE: extrusion frame ~3-4kg total -->
      <inertia ixx="0.02" ixy="0" ixz="0" iyy="0.02" iyz="0" izz="0.02"/>
    </inertial>
  </link>

  <!-- ==================== Camera Mast (3030 extrusion column) ============== -->
  <link name="mast_link">
    <visual>
      <origin xyz="0 0 ${mast_height/2}" rpy="0 0 0"/>
      <geometry>
        <box size="${mast_section} ${mast_section} ${mast_height}"/>
      </geometry>
      <material name="roscar_aluminum"/>
    </visual>
  </link>

  <joint name="mast_joint" type="fixed">
    <parent link="base_link"/>
    <child link="mast_link"/>
    <origin xyz="${mast_x} ${mast_y} ${chassis_height/2}" rpy="0 0 0"/>
  </joint>

  <!-- ==================== Wheel Macro ==================== -->
  <xacro:macro name="mecanum_wheel" params="name x_pos y_pos">
    <link name="${name}_wheel_link">
      <visual>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
        <material name="black"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="0.2"/>
        <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
      </inertial>
    </link>

    <joint name="${name}_wheel_joint" type="continuous">
      <parent link="base_link"/>
      <child link="${name}_wheel_link"/>
      <origin xyz="${x_pos} ${y_pos} ${-(chassis_z_offset + chassis_height/2 - wheel_radius)}"
              rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
    </joint>
  </xacro:macro>

  <!-- ==================== Four Wheels ==================== -->
  <xacro:mecanum_wheel name="front_left"  x_pos="${wheel_x_offset}"  y_pos="${wheel_y_offset}"/>
  <xacro:mecanum_wheel name="front_right" x_pos="${wheel_x_offset}"  y_pos="${-wheel_y_offset}"/>
  <xacro:mecanum_wheel name="rear_left"   x_pos="${-wheel_x_offset}" y_pos="${wheel_y_offset}"/>
  <xacro:mecanum_wheel name="rear_right"  x_pos="${-wheel_x_offset}" y_pos="${-wheel_y_offset}"/>

  <!-- ==================== IMU Link ==================== -->
  <link name="imu_link"/>

  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- ==================== D435i Depth Camera (mounted on mast) ============== -->
  <!-- realsense2_description's sensor_d435i macro creates camera_link plus    -->
  <!-- depth/color/IR child frames and their _optical variants. Parented to    -->
  <!-- base_link at the mount pose; the macro handles internal extrinsics.     -->
  <xacro:sensor_d435i parent="base_link" name="camera" use_nominal_extrinsics="true">
    <origin xyz="${d435i_x} ${d435i_y} ${d435i_z}" rpy="0 ${d435i_pitch} 0"/>
  </xacro:sensor_d435i>

  <!-- ==================== Lidar Link (RPLIDAR C1, on top of mast) ========== -->
  <!-- yaw=π: lidar's 0 deg marker physically points -X (away from camera).        -->
  <!-- Verified empirically 2026-04-28 — with yaw=0 the scan-matcher inferred      -->
  <!-- backward motion when the robot drove forward.                               -->
  <link name="laser">
    <visual>
      <geometry>
        <cylinder radius="0.035" length="0.040"/>
      </geometry>
      <material name="blue"/>
    </visual>
  </link>

  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="laser"/>
    <origin xyz="${lidar_x} ${lidar_y} ${lidar_z}" rpy="0 0 ${pi}"/>
  </joint>

</robot>
